<?xml version="1.0" encoding="UTF-8"?>
<AiEvaluationDefinition xmlns="http://soap.sforce.com/2006/04/metadata">
    <description>Functional tests for the Local Info Agent at Coral Cloud Resort.</description>
    <name>Local Info Agent Tests</name>
    <subjectName>Local_Info_Agent</subjectName>
    <subjectType>AGENT</subjectType>
    <testCase>
        <expectation>
            <expectedValue>local_weather</expectedValue>
            <name>topic_assertion</name>
        </expectation>
        <expectation>
            <expectedValue>[&apos;check_weather&apos;]</expectedValue>
            <name>actions_assertion</name>
        </expectation>
        <expectation>
            <expectedValue>The agent should provide a forecast with a temperature range for Coral Cloud Resort. The response should include both Celsius and Fahrenheit.</expectedValue>
            <name>output_validation</name>
        </expectation>
        <expectation>
            <name>coherence</name>
        </expectation>
        <expectation>
            <name>conciseness</name>
        </expectation>
        <expectation>
            <name>output_latency_milliseconds</name>
        </expectation>
        <inputs>
            <utterance>What&apos;s the weather like today?</utterance>
        </inputs>
        <number>1</number>
    </testCase>
    <testCase>
        <expectation>
            <expectedValue>local_events</expectedValue>
            <name>topic_assertion</name>
        </expectation>
        <expectation>
            <expectedValue>[&apos;check_events&apos;]</expectedValue>
            <name>actions_assertion</name>
        </expectation>
        <expectation>
            <expectedValue>The agent should provide information about movie events happening in Port Aurelia.</expectedValue>
            <name>output_validation</name>
        </expectation>
        <expectation>
            <name>coherence</name>
        </expectation>
        <expectation>
            <name>conciseness</name>
        </expectation>
        <expectation>
            <name>output_latency_milliseconds</name>
        </expectation>
        <inputs>
            <utterance>I like movies. What&apos;s showing nearby?</utterance>
        </inputs>
        <number>2</number>
    </testCase>
    <testCase>
        <expectation>
            <expectedValue>local_events</expectedValue>
            <name>topic_assertion</name>
        </expectation>
        <expectation>
            <expectedValue>[]</expectedValue>
            <name>actions_assertion</name>
        </expectation>
        <expectation>
            <expectedValue>Because the user has not indicated their interests, the agent should politely ask about the guest&apos;s interests before looking up events. The agent should NOT call check_events without knowing the guest&apos;s interests first.</expectedValue>
            <name>output_validation</name>
        </expectation>
        <expectation>
            <name>coherence</name>
        </expectation>
        <expectation>
            <name>output_latency_milliseconds</name>
        </expectation>
        <inputs>
            <utterance>What events are happening around here?</utterance>
        </inputs>
        <number>3</number>
    </testCase>
    <testCase>
        <expectation>
            <expectedValue>resort_hours</expectedValue>
            <name>topic_assertion</name>
        </expectation>
        <expectation>
            <expectedValue>[&apos;get_resort_hours&apos;]</expectedValue>
            <name>actions_assertion</name>
        </expectation>
        <expectation>
            <expectedValue>The agent should provide opening and closing times for the spa. The agent should mention that a reservation is required and provide the phone number (555) 867-5309.</expectedValue>
            <name>output_validation</name>
        </expectation>
        <expectation>
            <name>coherence</name>
        </expectation>
        <expectation>
            <name>conciseness</name>
        </expectation>
        <expectation>
            <name>output_latency_milliseconds</name>
        </expectation>
        <inputs>
            <utterance>When does the spa open?</utterance>
        </inputs>
        <number>4</number>
    </testCase>
</AiEvaluationDefinition>
